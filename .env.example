# MegaDoc Environment Configuration
# Copy this file to .env and customize for your deployment

# Required for production (generate a strong random string)
SECRET_KEY=your-secret-key-change-in-production

# Optional: Enable AI chat features (get key from https://openrouter.ai)
OPENROUTER_API_KEY=

# Optional: Enable debug mode (set to true for development)
FLASK_DEBUG=false

# Optional: File upload limits
MAX_FILE_SIZE=52428800  # 50MB in bytes

# Optional: Rate limiting
RATE_LIMIT_REQUESTS=200  # requests per window
RATE_LIMIT_WINDOW=60     # window in seconds
